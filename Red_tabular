],"execution_count":null},{"cell_type":"code","source":"ITERS = 200\n\nentrenar(\n    loader_entrenamiento, modelo, funcion_error, optimizador_smote, True, 2, 0.5, True, 5, 0.5, loader_prueba, ITERS, \"auc\"\n)","metadata":{"trusted":true,"scrolled":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Modelo SMOTE","metadata":{}},{"cell_type":"code","source":"class RedNeuronalSmote(nn.Module):\n    def __init__(self):\n        super(RedNeuronalSmote, self).__init__()\n\n        self.capas = nn.Sequential(\n            nn.Linear(44, 12),\n            nn.ReLU(),\n            nn.Linear(12,8),\n            nn.ReLU(),\n            nn.Linear(8,11),\n            nn.ReLU(),\n            nn.Linear(11,12),\n            nn.ReLU(),\n            # Capa salida\n            nn.Linear(12,1)\n        )\n\n        self._inicializar_pesos()\n\n    def _inicializar_pesos(self):\n        for nombre, parametro in self.capas.named_parameters():\n            if \"weight\" in nombre:\n                nn.init.xavier_normal_(parametro)\n            elif \"bias\" in nombre:\n                nn.init.constant_(parametro, 0.0)\n\n    def forward(self, x: Tensor):\n        return self.capas(x)\n\nmodelo_smote = RedNeuronalSmote()\nfuncion_error = nn.BCELoss()\noptimizador_smote = torch.optim.SGD(modelo_smote.parameters(), lr=1e-3)\n\nsmote = SMOTE(random_state=123, sampling_strategy=\"minority\", k_neighbors=30)\nnuevo_x, nuevo_y= smote.fit_resample(entrenamiento.drop(columns=[\"TEP\"]), entrenamiento[\"TEP\"])\n\nentrenamiento_smote = concat([nuevo_x,nuevo_y], axis=1)\ndatos_entrenamiento_smote = DatosTep(entrenamiento_smote)\nloader_entrenamiento_smote = DataLoader(datos_entrenamiento_smote,batch_size=BATCH_SIZE)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:52:41.186719Z","iopub.execute_input":"2026-02-24T16:52:41.187181Z","iopub.status.idle":"2026-02-24T16:52:41.200644Z","shell.execute_reply.started":"2026-02-24T16:52:41.187155Z","shell.e