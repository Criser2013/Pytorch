{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":11265967,"datasetId":7042060,"databundleVersionId":11682252}],"dockerImageVersionId":31286,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/criser2013/red-tabular-pytorch?scriptVersionId=299799682\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"markdown","source":"Modelo de perceptrón multicapa para clasificación binaria\n\n# Importando librerías","metadata":{}},{"cell_type":"code","source":"from pandas import read_excel, concat, DataFrame\nfrom imblearn.over_sampling import SMOTE\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import accuracy_score, recall_score, precision_score, roc_auc_score, confusion_matrix\nfrom torch.utils.data import Dataset, DataLoader\nfrom torch import Tensor\nfrom torch import nn\nimport numpy as np\nimport torch\nimport warnings\n\nnp.random.seed(0)\ntorch.manual_seed(0)\nwarnings.filterwarnings(\"ignore\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:17:42.911269Z","iopub.execute_input":"2026-02-24T16:17:42.912057Z","iopub.status.idle":"2026-02-24T16:17:48.928906Z","shell.execute_reply.started":"2026-02-24T16:17:42.912022Z","shell.execute_reply":"2026-02-24T16:17:48.928044Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Carga de datos","metadata":{}},{"cell_type":"code","source":"datos = read_excel(\"/kaggle/input/datasets/criser2013/datos-tep/Datos preprocesados.xlsx\")\n\nentrenamiento, prueba = train_test_split(datos, train_size=0.7, test_size=0.3, random_state=123)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:17:50.984654Z","iopub.execute_input":"2026-02-24T16:17:50.985429Z","iopub.status.idle":"2026-02-24T16:17:51.837476Z","shell.execute_reply.started":"2026-02-24T16:17:50.985397Z","shell.execute_reply":"2026-02-24T16:17:51.836702Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Funciones y clases auxiliares","metadata":{}},{"cell_type":"code","source":"class DatosTep(Dataset):\n    def __init__(self, instancias: DataFrame):\n        self.instancias = instancias.copy()\n        self.y = instancias[\"TEP\"]\n        self.instancias.drop(columns=[\"TEP\"], inplace=True)\n\n    def __len__(self):\n        return len(self.instancias)\n\n    def __getitem__(self, idx: int):\n        x = torch.tensor(self.instancias.iloc[idx,:].to_numpy(), dtype=torch.float32)\n        y = torch.tensor(self.y.iloc[idx], dtype=torch.float32)\n        return x, y\n\nclass EarlyStopping:\n    def __init__(self, paciencia=5, delta=0.5):\n        self.paciencia = paciencia\n        self.delta = delta\n        self.mejor_valor = None\n        self.detener = False\n        self.contador = 0\n        self.mejor_estado = None\n        self.mejor_iter = None\n\n    def evaluar_detencion(self, error: float, modelo, iteracion: int):\n        if self.mejor_valor is None:\n            self.mejor_valor = error\n            self.mejor_estado = modelo.state_dict()\n            self.mejor_iter = iteracion\n        elif (self.mejor_valor - error) < self.delta:\n            self.contador += 1\n            self.detener = self.contador >= self.paciencia\n        else:\n            self._mejor_valor = error\n            self.mejor_estado = modelo.state_dict()\n            self.contador = 0\n            self.mejor_iter = iteracion\n            \n    def cargar_mejor_modelo(self, modelo):\n        modelo.load_state_dict(self.mejor_estado)\n\n    def ver_mejor_iter(self):\n        return self.mejor_iter\n\ndef specificity_score(y: list[int], y_pred: list[int]) -> float:\n    MATRIZ = confusion_matrix(y, y_pred)\n    VN = MATRIZ[0][0]\n    FP = MATRIZ[0][1]\n\n    return VN / (VN + FP)\n\ndef regularizacion(parametros: list[Tensor], coef: float, tipo: int = 1) -> float:\n    if tipo == 1:\n        return coef*sum(i.abs().sum() for i in parametros)\n    else:\n        return coef*sum(i.pow(2).sum() for i in parametros)\n\ndef entrenar(\n    dataloader: DataLoader, modelo, funcion_perdida, optimizador, regul: bool = False, tipo_regularizacion: int = 1, \n    coef_regularizacion: float = 0.3, earlystop = False, paciencia: int = 5 , delta: float = 0.5, dataloader_validacion: DataLoader = None,\n    iteraciones: int = 5, metrica: str = \"error\", verbose: bool = False\n):\n    TAM = len(dataloader.dataset)\n    early_stopping = EarlyStopping(paciencia, delta) if earlystop else None\n    for i in range(iteraciones):\n        print(f\"Iteración {i+1}\\n---------------------------------------\")\n        modelo.train()\n        acum = 1\n        for X, y in dataloader:\n            # Convierte el tensor a 1-dimensión\n            y = torch.unsqueeze(y, 1)\n            # Calculo del error\n            y_gorro = modelo(X)\n            y_gorro = torch.sigmoid(y_gorro)\n            coef_regul = regularizacion(modelo.parameters(), coef_regularizacion, tipo_regularizacion) if regul else 0\n            error = funcion_perdida(y_gorro, y) + coef_regul\n    \n            # Retropropagación\n            error.backward()\n            optimizador.step()\n            optimizador.zero_grad()\n    \n            acum += len(X)\n            perdida, instancias = error.item(), acum - 1\n            print(f\"Error: {perdida:>7f}  [{instancias:>5d}/{TAM:>5d}]\")\n    \n        if earlystop:\n            metricas = probar(dataloader_validacion, modelo, funcion_perdida, verbose)\n            early_stopping.evaluar_detencion(metricas[metrica], modelo, i, metrica)\n    \n            if early_stopping.detener:\n                early_stopping.cargar_mejor_modelo(modelo)\n                break\n        print(\"---------------------------------------\")\n    print(\"¡Entrenamiento terminado!\")\n    \n\ndef probar(dataloader: DataLoader, modelo, funcion_perdida, verbose = True):\n    TAM = len(dataloader.dataset)\n    NUM_LOTES = len(dataloader)\n    # Coloca el modelo en modo de inferencia, por lo que desactiva capas como dropout y normalización\n    modelo.eval()\n\n    error = 0\n    Y, y_pred, probs = [], [], []\n    \n    with torch.no_grad():\n        for X, y in dataloader:\n            y = torch.unsqueeze(y, 1)\n            y_gorro = modelo(X)\n            y_gorro = torch.sigmoid(y_gorro)\n\n            preds = (y_gorro >= 0.5).float()\n            error += funcion_perdida(y_gorro, y).item()\n\n            Y.extend(y.numpy())\n            y_pred.extend(preds.numpy())\n            probs.extend(y_gorro.numpy())\n            \n    error /= NUM_LOTES\n\n    accuracy = accuracy_score(Y, y_pred)\n    recall = recall_score(Y, y_pred)\n    precision = precision_score(Y, y_pred)\n    specificity = specificity_score(Y, y_pred)\n    auc = roc_auc_score(Y, probs)\n\n    if verbose:\n        print(f\"\\nError promedio: {error:>7f}, accuracy: {(100*accuracy):0.2f}%, recall: {(100*recall):0.2f}%, precision: {(100*precision):0.2f}%, specificity: {(100*specificity):0.2f},  AUC {(100*auc):0.2f}%\")\n\n    return {\"accuracy\": accuracy, \"recall\": recall, \"precision\": precision, \"specificity\": specificity, \"auc\": auc, \"error\": error}","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:21:44.397761Z","iopub.execute_input":"2026-02-24T16:21:44.398528Z","iopub.status.idle"