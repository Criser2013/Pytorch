{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":11265967,"datasetId":7042060,"databundleVersionId":11682252}],"dockerImageVersionId":31286,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/criser2013/red-tabular-pytorch?scriptVersionId=303196314\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"markdown","source":"Modelo de perceptrón multicapa para clasificación binaria\n\n# Importando librerías","metadata":{}},{"cell_type":"code","source":"from pandas import read_excel, concat, DataFrame\nfrom imblearn.over_sampling import SMOTE\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import accuracy_score, recall_score, precision_score, roc_auc_score, confusion_matrix\nfrom torch.utils.data import Dataset, DataLoader\nfrom torch import Tensor\nfrom torch import nn\nimport numpy as np\nimport torch\nimport warnings\n\nnp.random.seed(0)\ntorch.manual_seed(0)\nwarnings.filterwarnings(\"ignore\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:17:42.911269Z","iopub.execute_input":"2026-02-24T16:17:42.912057Z","iopub.status.idle":"2026-02-24T16:17:48.928906Z","shell.execute_reply.started":"2026-02-24T16:17:42.912022Z","shell.execute_reply":"2026-02-24T16:17:48.928044Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Carga de datos","metadata":{}},{"cell_type":"code","source":"datos = read_excel(\"/kaggle/input/datasets/criser2013/datos-tep/Datos preprocesados.xlsx\")\n\nentrenamiento, prueba = train_test_split(datos, train_size=0.7, test_size=0.3, random_state=123)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:17:50.984654Z","iopub.execute_input":"2026-02-24T16:17:50.985429Z","iopub.status.idle":"2026-02-24T16:17:51.837476Z","shell.execute_reply.started":"2026-02-24T16:17:50.985397Z","shell.execute_reply":"2026-02-24T16:17:51.836702Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Funciones y clases auxiliares\n\n## Early stopping\nEs una técnica consiste en almacenar el mejor estado (parámetros) del modelo a partir de evaluar una métrica (magnitud del error, MSE, AUC, accuracy, etc.) que se obtenga con un conjunto de prueba/validación cada iteración. Si después de una cantidad establecida de iteraciones (parámetro `paciencia`) la métrica proveída no supera el umbral de mejora (`delta`), el entrenamiento se detiene y se carga el estado con las mejores métricas que se haya almacenado. En caso contrario el entrenamiento continua.  \n\nEste callback tiene 2 hiperparámetros:\n\n- **paciencia:** Número de iteraciones en las que espera ue la métrica sufra cambios que superen el umbral `delta`. Si no hay cambios pasada la cantidad de iteraciones establecida, se detendrá el entrenamiento y cargará el estado (parámetros) del modelo en la iteración se que obtuvo la mejor métrica. Para evaluar la detención se usa la expresión $metrica_{mejor_valor}-metrica_{actual}<delta$\n- **delta:** Umbral en el que se espera que la métrica a evaluar sufra cambios que mejoren el modelo.\n\nEsta técnica se puede implementar mediante la librería `pytorch-ignite` o con la implementación manual definida.","metadata":{}},{"cell_type":"code","source":"class EarlyStopping:\n    def __init__(self, paciencia=5, delta=0.5):\n        \"\"\"\n        Inicializa el callback y establece los hiperparámetros que seguirá el modelo.\n        \n        Args:\n            paciencia (int): Número de iteraciones que el callback esperará cambios en la métrica antes de detener el entrenamiento.\n            delta (float): Umbral mínimo que se espera que la métrica cambie.\n        \"\"\"\n        self.paciencia = paciencia\n        self.delta = delta\n        # Almacena el mejor valor de la métrica que se provea.\n        self.mejor_valor = None\n        # Controla la detención del modelo.\n        self.detener = False\n        # Cuenta la cantidad de iteraciones en las que la métrica proveída no ha superado el umbral de cambio.\n        self.contador = 0\n        # Almacena el mejor estado del modelo.\n        self.mejor_estado = None\n        # Almacena la iteración (número) en que se ha obtenido el mejor valor de la métrica\n        self.mejor_iter = 1\n\n    def evaluar_detencion(self, error: float, modelo, iteracion: int):\n        \"\"\"\n        Evalua si es necesario detener el entrenamiento del modelo si no hay cambios significativos en la métrica proveída.\n\n        Args:\n            error (float): Valor de la métrica o la función de error en la iteración actual.\n            modelo (torch.nn.Module): Modelo de red neuronal que se está entrenando.\n            iteración (int): Iteración actual.\n        \"\"\"\n        # Cuando el modelo se inicializa se establece la primera iteración como el mejor estado.\n        if self.mejor_valor is None:\n            self.mejor_valor = error\n            self.mejor_estado = modelo.state_dict()\n        # Evalua si el cambios en la métrica entre la iteración actual y el mejor valor registrado no supera el umbral.\n        elif (self.mejor_valor - error) < self.delta:\n            self.contador += 1\n            self.detener = self.contador >= self.paciencia\n        # En caso de que haya un cambio significativo, se establece la iteración actual como el mejor estado.\n        else:\n            self._mejor_valor = error\n            self.mejor_estado = modelo.state_dict()\n            self.contador = 0\n            self.mejor_iter = iteracion\n            \n    def cargar_mejor_modelo(self, modelo):\n        \"\"\"\n        Carga el mejor estado registrado en el modelo.\n\n        Args:\n            modelo (torch.nn.Module): Modelo de red neuronal que se está entrenando.\n        \"\"\"\n        modelo.load_state_dict(self.mejor_estado)\n\n    def ver_mejor_iter(self):\n        \"\"\"\n        Retorna la iteración en la que se obtuvo el mejor estado (mejor métrica).\n\n        Returns:\n            int: Iteración en la que se obtuvo la mejor métrica.\n        \"\"\"\n        return self.mejor_iter","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Regularización L1, L2 y ElasticNet \n\nEsta técnica consiste en sumar una constante ($C_{regularización}$) al error calculado por la función de pérdida ($L_{total}$) para añadir una penalización al modelo. Esto previene el sobreajuste y permite que los modelos puedan evitar quedarse atascados en mínimos locales.\n\n<center>\n    $L_{total}=L_{i}+C_{regularización}$\n</center>\n\n- **L1 (Lasso):** Esta constante se obtiene a partir del sumar el valor absoluto de los parámetros del modelo y multiplicarlos por un coeficiente $\\lambda$. Permite que los modelos sean más robustos hacia el ruido reduciendo la complejidad del mismo dado que tiene a establecer algunos pesos en 0, por lo que \"elimina\" las características menos importantes. De igual forma un modelo que implemente esta técnica es más fácil de interpretar dado que genera un efecto de dispersión sobre la matriz de pesos.\n\n<center>\n    $C_{regularización} = L_{1}=\\lambda\\sum_{w \\in W} |w|$\n</center>\n\n- **L2 (Rigde - weight decay):** Es la suma de los cuadrados de los parámetros del modelo multiplicados por una constante lambda. Como consecuencia, tiende a producir modelos con pesos uniformemente distribuidos. A diferencia de L1, no obliga a que los pesos sean exactamente 0, por lo que se reduce la complejidad y evita el sobreajuste del modelo. Tamibén reduce la influencia de características sin importancia y aumenta la estabilidad numérica cuando los atributos están correlacionados.\n\n<center>\n    $C_{regularización} = L_{2}=\\lambda\\sum_{w \\in W} w^{2}$\n</center>\n\n- **ElasticNet (mixta):** Consiste en combinar las estrategias L1 y L2. Tiene todas las ventajas y desventajas de ambas estrategias, por lo que consigue una forma de penalización más flexible. Se recomienda utilizarla cuando los atributos del modelo están correlacionados o cuando hay un gran número de estos. Dado que utiliza ambas estrategias, se requiere establecer los coeficientes de regularización $\\lambda_{1}$ y $\\lambda_{2}$ para ambos coeficientes.\n\n<center>\n    $C_{regularización} = \\lambda_{1}\\sum_{w \\in W} |w| + \\lambda_{2}\\sum_{w \\in W} w^{2}$\n</center>","metadata":{}},{"cell_type":"code","source":"def regularizacion(parametros: list[Tensor], tipo: int = 1, coef_1: float = 0.1, coef_2: float = 0.1) -> float:\n    \"\"\"\n    Aplica regularización L1 o L2 (weight decay) a los parámetros del modelo.\n\n    Args:\n        parametros (list[Tensor]): Parámetros del modelo (matriz de pesos).\n        tipo (int[1|2|3]): Tipo de regularización a utilizar. Para L1 utilice el valor 1,  para L2 el valor 2 y para ElasticNet\n        utilice el valor 3.\n        coef_1 (float): Coeficiente de regularización. Si está utilizando ElasticNet, se aplicará al factor L1. En caso contrario \n        es el coeficiente que se utilizará para la regularización L1 o L2 (según lo que haya escogido).\n        coef_2 (float): Coeficiente de regularización para L2. Este parámetro solo es requerido si desea utilizar ElasticNet.\n\n    Returns:\n       float: Valor del coeficiente de regularización.\n    \"\"\"\n    match (tipo):\n        case 1:\n            return coef_1*sum(i.abs().sum() for i in parametros)\n        case 2:\n            return coef_1*sum(i.pow(2).sum() for i in parametros)\n        case 3:\n            return (coef_1*sum(i.abs().sum() for i in parametros)) + (coef_2*sum(i.pow(2).sum() for i in parametros))\n        case _:\n            raise ValueError(\"Valor del parámetro 'tipo' inválido.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Función de entrenamiento\n\nEsta función realiza el entrenamiento del modelo recorriendo cada lote del conjunto de entrenamiento para ajustar los parámetros utilizando retropropagación. ","metadata":{}},{"cell_type":"code","source":"def entrenar(\n    dataloader_entrenamiento: DataLoader, modelo, funcion_perdida, optimizador, iteraciones: int = 5,\n    regularizacion: bool = False, tipo_regularizacion: int = 1, coef1_regularizacion: float = 0.3,\n    coef1_regularizacion: float = 0.3, earlystop: bool = False, paciencia: int = 5 , delta: float = 0.5,\n    dataloader_validacion: DataLoader = None, metrica: str = \"error\", verbose: bool = False\n):\n    \"\"\"\n    Entrena el modelo utilizando el conjunto de datos de entrenamiento durante la cantidad de iteraciones que se establezca. \n    También permite activar las funciones de regularización y early stopping durante el entrenamiento.\n\n    Args:\n        dataloader_entrenamiento (DataLoader): Dataloader que contiene la instancia del conjunto de entrenamiento.\n        \n        modelo (torch.nn.Module): Modelo de red neuronal a entrenar.\n        \n        funcion_perdida (torch.nn.Loss): Función de pérdida (no debe calcular logits).\n        \n        optimizador (torch.optim): Optimizador del modelo.\n        iteraciones (int): Cantidad de iteraciones a entrenar el modelo. El valor predeterminado es 5.\n        \n        regularización (bool): Activa o desactiva la regularización durante el entrenamiento (L1, L2 o ElasticNet). De forma \n        predeterminada está desactivada (valor False).\n        \n        tipo_regularizacion (int[1|2|3]): Tipo de regularización a utilizar. Valor 1 para L1, 2 para L2 y 3 para ElasticNet.\n        \n        coef1_regularización (float): Valor del coeficiente de regularización en caso de utilizar L1 o L2. Si el tipo de \n        regularización es ElasticNet, este será el coeficiente lambda_1 que afectará L1. Es obligatorio si se activa la regularización.\n        \n        coef2_regularizacion (float): Valor del coeficiente de regularización que afecta a L2 si se utiliza ElasticNet. En\n        caso contrario no afectará la función de pérdida.\n\n        earlystop (bool): Activa o desactiva el early stopping durante el entrenamiento. Valor True para activarlo. De forma \n        predeterminada está desactivado (valor False).\n\n        paciencia (int): Cantidad de iteraciones que el early stopping aguardará por cambios en la métrica establecida. De forma \n        predeterminada el valor es 5.\n\n        delta (float): Umbral mínimo que se espera que la métrica seleccionada cambie (se usa en el early stopping).\n\n        dataloader_validacion (DataLoader): Dataloader del conjunto de validación. Obligatorio si se activa el early stopping.\n\n        metrica (str): Métrica con la que se evaluará el earlystopping. Los valores posibles son \"error\" (magnitud de la función de pérdida), \n        \"accuracy\", \"auc\", \"recall\", \"specificity\", \"precision\".\n\n        verbose (bool): Indicador para activar que se muestren mensajes con las métricas que obtiene el modelo al ser evaluado con el \n        conjunto de validación.\n    \"\"\"\n    TAM = len(dataloader.dataset)\n    early_stopping = EarlyStopping(paciencia, delta) if earlystop else None\n    iteraciones = int(iteraciones)\n\n    if metrica not in (\"error\", \"auc\", \"accuracy\", \"recall\", \"precision\", \"specificity\"):\n        raise ValueError(f\"La métrica {metrica} no está entre las opciones disponibles.\")\n    \n    for i in range(iteraciones):\n        print(f\"Iteración {i+1}\\n---------------------------------------\")\n        # Se activa el modo de entrenamiento en el modelo para activar capas de dropout, etc.\n        modelo.train()\n        acum = 1\n        # Recorriendo los lotes del conjunto de entrenamiento\n        for X, y in dataloader_entrenamiento:\n            # Convierte el tensor a 1-dimensión\n            y = torch.unsqueeze(y, 1)\n            # Calculo del error\n            y_gorro = modelo(X)\n            # Dado que se utiliza BCELoss y no BCEWithLogitsLoss debe calcularse manualmente la activación de la última neurona\n            # utilizando la función sigmoide\n            y_gorro = torch.sigmoid(y_gorro)\n            # Si se activa la regularización, se calcula el coeficiente (dependiendo del 'tipo_regularizacion') y se suma a la\n            # función de pérdida\n            coef_regul = regularizacion(modelo.parameters(), tipo_regularizacion, coef1_regularizacion, coef2_regularizacion) if regularizacion else 0\n            error = funcion_perdida(y_gorro, y) + coef_regul\n    \n            # Retropropagación\n            # Calculo de los gradientes\n            error.backward()\n            # Se actualizan los pesos del modelo\n            optimizador.step()\n            # Se reinician los gradientes en 0\n            optimizador.zero_grad()\n    \n            acum += len(X)\n            perdida, instancias = error.item(), acum - 1\n            print(f\"Error: {perdida:>7f}  [{instancias:>5d}/{TAM:>5d}]\")\n\n        # Si se activa el Early stopping, se evalua el rendimiento a partir de la métrica especificada utilizando\n        # el conjunto de validación proveído.\n        if earlystop:\n            # Calculo de las métricas sobre el conjunto de validación\n            metricas = probar(dataloader_validacion, modelo, funcion_perdida, verbose)\n            # Evaluación del early stopping\n            early_stopping.evaluar_detencion(metricas[metrica], modelo, i, metrica)\n\n            if early_stopping.detener:\n                early_stopping.cargar_mejor_modelo(modelo)\n                break\n        print(\"---------------------------------------\")\n    print(\"¡Entrenamiento terminado!\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Función de prueba\nEsta función permite realizar inferencias en el modelo a partir de los datos de prueba que se provean. También calcula las métricas del modelo sobre este conjunto","metadata":{}},{"cell_type":"code","source":"def probar(dataloader: DataLoader, modelo, funcion_perdida, verbose = True):\n    \"\"\"\n    Realiza inferencias al modelo sobre el conjunto de prueba que se provea, también calcula las métricas del mismo.\n\n    Args:\n        dataloader (DataLoader): Dataloader del conjunto de prueba.\n        modelo (torch.nn.Module): Modelo de red neuronal a evaluar.\n        funcion_perdida (torch.nn.Loss): Función de pérdida (no debe calcular logits).\n        verbose (bool): Indicador para activar que se muestren mensajes con las métricas que obtiene el modelo al ser evaluado.\n\n    Returns:\n        dict: Métricas del modelo sobre el conjunto de datos (auc, error promedio, accuracy, recall, precision y specificity).\n    \"\"\"\n    TAM = len(dataloader.dataset)\n    NUM_LOTES = len(dataloader)\n\n    # Inicialización de métricas.\n    error = 0\n    Y, y_pred, probs = [], [], []\n    \n    # Coloca el modelo en modo de inferencia, por lo que desactiva capas como dropout y normalización\n    modelo.eval()\n\n    # Se desactiva el calculo de los gradientes sobre los tensores del modelo\n    with torch.no_grad():\n        # Recorriendo cada lote del conjunto de prueba\n        for X, y in dataloader:\n            y = torch.unsqueeze(y, 1)\n            # Inferencia del modelo sobre el lote de datos.\n            y_gorro = modelo(X)\n            y_gorro = torch.sigmoid(y_gorro)\n            error += funcion_perdida(y_gorro, y).item()\n\n            # Codificación de la salida a las etiquetas\n            preds = (y_gorro >= 0.5).float()\n\n            # Concatenando las salidas, inferencias del modelo y probabilidades\n            Y.extend(y.numpy())\n            y_pred.extend(preds.numpy())\n            probs.extend(y_gorro.numpy())\n\n    # Error promedio\n    error /= NUM_LOTES\n\n    # Calculo de métricas\n    accuracy = accuracy_score(Y, y_pred)*100\n    recall = recall_score(Y, y_pred)*100\n    precision = precision_score(Y, y_pred)*100\n    specificity = specificity_score(Y, y_pred)*100\n    auc = roc_auc_score(Y, probs)*100\n\n    if verbose:\n        print(f\"\\nError promedio: {error:>7f}, accuracy: {accuracy:0.2f}%, recall: {recall:0.2f}%, precision: {precision:0.2f}%, specificity: {specificity:0.2f},  AUC ROC {auc:0.2f}%\")\n\n    return {\"accuracy\": accuracy, \"recall\": recall, \"precision\": precision, \"specificity\": specificity, \"auc\": auc, \"error\": error}","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Métricas\nDado que se trata de un problema de clasificación binaria, las métricas a evaluar son:\n- **AUC:** Área bajo la curva ROC del modelo.\n- **Accuracy:** Proporción de instancias correctamente clasificadas.\n- **Precision:** Proporción de instancias correctamente clasificadas en la clase positiva.\n- **Recall:** Proporción de instancias de la clase positiva correctamente clasificadas.\n- **Specificity:** Proporción de instancias de la clase negativa correctamente clasificadas.\nCasi todas las métricas están implementadas en `scikit-learn`, sin embargo, la métrica \"specificity\" no lo está por lo que se utiliza una implementación manual.","metadata":{}},{"cell_type":"code","source":"def specificity_score(y: list[int], y_pred: list[int]) -> float:\n    \"\"\"\n    Calcula la métrica \"specifity\" a partir de las etiquetas de clase y etiquetas predichas por el modelo.\n    \n    Args:\n        y (list|ndarray[int]): Etiqueta de clase de las instancias.\n        y_pred (list|ndarray[int]): Etiquetas de clase predichas por el modelo para cada instancia.\n    Return:\n        float: Proporción de instancias correctamente clasificadas en la clase negativa.\n    \"\"\"\n    MATRIZ = confusion_matrix(y, y_pred)\n    VN = MATRIZ[0][0]\n    FP = MATRIZ[0][1]\n\n    return VN / (VN + FP)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Dataloader\n\nDado que el conjunto de datos es pequeño y no tiene cambios significativos entre las variables, solo debe proveerse el dataframe con los datos y este separará la etiqueta de clase del resto de atributos. El resto de métodos solo convierten las instancias a tensor.","metadata":{}},{"cell_type":"code","source":"class DatosTep(Dataset):\n    def __init__(self, instancias: DataFrame):\n        \"\"\"\n        Inicializa el conjunto de datos a partir de las instancias que se provean. Separa la etiqueta de clase de \n        los demás atributos.\n\n        Args:\n            instancias (DataFrame): Instancias del conjunto de datos, debe contener una columna con nombre \"TEP\".\n        \"\"\"\n        self.instancias = instancias.copy()\n        self.y = instancias[\"TEP\"]\n        self.instancias.drop(columns=[\"TEP\"], inplace=True)\n\n    def __len__(self):\n        return len(self.instancias)\n\n    def __getitem__(self, idx: int):\n        # Se obtienen todas las columnas de la instancia y se convierte a array de numpy para volverse un tensor.\n        x = torch.tensor(self.instancias.iloc[idx,:].to_numpy(), dtype=torch.float32)\n        # Se toma la etiqueta y se convierte a tensor\n        y = torch.tensor(self.y.iloc[idx], dtype=torch.float32)\n        return x, y","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-24T16:21:44.397761Z","iopub.execute_input":"2026-02-24T16:21:44.398528Z","iopub.status.idle":"2026-02-24T16:21:44.407201Z","shell.execute_reply.started":"2026-02-24T16:21:44.398497Z","shell.execute_reply":"2026-02-24T16:21:44.406201Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Modelo de red neuronal normal","metadata":{}},{"cell_type":"code","source":"class RedNeuronal(nn.Module):\n    def __init__(self):\n        super(RedNeuronal, self).__init__()\n\n        self.capas = nn.Sequential(\n            nn.Linear(44, 4),\n            nn.BatchNorm1d(4),              # La normalización del lote se aplica antes de calcular la activación de las neuronas\n            nn.Tanh(),\n            nn.Linear(4,10),\n            nn.BatchNorm1d(10),\n            nn.Tanh(),\n            nn.Linear(10,15),\n            nn.BatchNorm1d(15),\n            nn.Tanh(),\n            nn.Linear(15,5),\n            nn.Tanh(),\n            # Capa salida\n            nn.Linear(5,1)\n        )\n\n        self._inicializar_pesos()\n\n    def _inicializar_pesos(self):\n        for nombre, parametro in self.capas.named_parameters():\n            if \"weight\" in nombre:\n                nn.init.xavier_normal_(parametro)\n            elif \"bias\" in nombre:\n                nn.init.constant_(parametro, 0.0)\n\n    def forward(self, x):\n        return self.capas(x)\n\nBATCH_SIZE = 32\n\ndatos_entrenamiento = DatosTep(entrenamiento)\ndatos_prueba = DatosTep(prueba)\n\nloader_entrenamiento = DataLoader(datos_entrenamiento,batch_size=BATCH_SIZE, shuffle=True)\nloader_prueba = DataLoader(datos_prueba, batch_size=BATCH_SIZE, shuffle=True)\n\nmodelo = RedNeuronal()\nfuncion_error = nn.BCELoss()\noptimizador = torch.optim.Adam(modelo.parameters(), lr=1e-3)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-21T17:21:54.594429Z","iopub.execute_input":"2026-02-21T17:21:54.594932Z","iopub.status.idle":"2026-02-21T17:21:57.282824Z","shell.execute_reply.started":"2026-02-21T17:21:54.594903Z","shell.execute_reply":"2026-02-21T17:21:57.281891Z"}},"outputs":[],"execution_coun