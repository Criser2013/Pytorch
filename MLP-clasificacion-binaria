lo estableciendo los nombres de los atributos en los nodos de entrada del grafo.\nmodelo_onnx = torch.onnx.export(modelo, input_names=list(entrenamiento.drop(columns=[\"TEP\"]).columns), dynamo=True)\n\nmodelo_onnx.save(\"modelo.onnx\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Clasificación utilizando onnxruntime","metadata":{}},{"cell_type":"code","source":"from onnxruntime import InferenceSession\n\n\"\"\"\nLos datos se pasan como un diccionario donde las llaves son los nombres de las entradas del modelo y los valores son numpy arrays float32. Cada valor en cada clave\nrepresenta una instancia a predecir\n\"\"\"\n\nsess = InferenceSession(\"modelo.onnx\", providers=['CPUExecutionProvider'])\n\nmapper = {\"Inmovilidad de M inferiores\": \"Inmovilidad_de_M_inferiores\", \"Procedimiento Quirurgicos / Traumatismo Grave en los últimos 15 dias\": \"Procedimiento_Quirurgicos___Traumatismo_Grave_en_los_últimos_15_dias\",\n          \"Viaje prolongado\": \"Viaje_prolongado\", \"Síntomas disautonomicos\": \"Síntomas_disautonomicos\", \"Edema de M inferiores\": \"Edema_de_M_inferiores\", \"Diabetes Mellitus\": \"Diabetes_Mellitus\",\n          \"Hipertensión arterial\": \"Hipertensión_arterial\", \"Enfermedad coronaria\": \"Enfermedad_coronaria\", \"Dolor toracico\": \"Dolor_toracico\", \"TEP - TVP Previo\": \"TEP___TVP_Previo\",\n          \"Frecuencia respiratoria\": \"Frecuencia_respiratoria\", \"Presión sistólica\": \"Presión_sistólica\", \"Presión diastólica\": \"Presión_diastólica\",\n\t\t  \"Saturación de la sangre\": \"Saturación_de_la_sangre\", \"Frecuencia cardíaca\": \"Frecuencia_cardíaca\"}\n\n# Entrada como diccionario\ninput_name = [i.name for i in sess.get_inputs()]\ndatos_prueba.rename(columns=mapper, inplace=True)\n\npred2 = sess.run(None, {i: datos_prueba[i].astype(float32).to_numpy().reshape(-1, 1) for i in input_name})\n\nprint(f\"Predicción para el conjunto de prueba: {pred2[0]}\")","metadata"